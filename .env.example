# Solas Billing Environment Variables
# Copy this file to .env and fill in your keys

# LLM Provider Keys (at least one required for proxy forwarding)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# Server Configuration
PORT=8080
NODE_ENV=development

# Rust Leaf Engine (optional high-performance proxy)
LEAF_PORT=9090
DATABASE_URL=../server/solas.db

# Stripe Integration (optional)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Analytics Sink (optional — Tinybird / ClickHouse)
TINYBIRD_INGEST_URL=
TINYBIRD_TOKEN=
